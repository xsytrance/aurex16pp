+    fn hp_decay_q6(self) -> i32 {
+        match self {
+            Self::Soft => 61,
+            Self::Default => 63,
+            Self::Arcade => 64,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::Soft => "soft",
+            Self::Default => "default",
+            Self::Arcade => "arcade",
+        }
+    }
+
+    pub fn parse(s: &str) -> Option<Self> {
+        match s {
+            "soft" => Some(Self::Soft),
+            "default" => Some(Self::Default),
+            "arcade" => Some(Self::Arcade),
+            _ => None,
